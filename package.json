{
  "name": "tw-stock-analysis",
  "version": "2.1.0",
  "description": "Taiwan Stock Intelligent Analysis System - 台股智能分析系統",
  "author": "Ming",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "npm run build && node dist/src/main",
    "start:nest": "NODE_NO_WARNINGS=1 nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "fetch:recent": "npm run build && node dist/scripts/fetch-recent-data",
    "fetch:historical": "npm run build && node dist/scripts/fetch-historical-data",
    "fetch:quick": "npm run build && node dist/scripts/fetch-historical-data -- --quick",
    "optimize:indexes": "npm run build && node dist/scripts/optimize-indexes",
    "check:integrity": "npm run build && node dist/scripts/check-data-integrity",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/cache-manager": "^2.1.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.0.0",
    "@nestjs/mongoose": "^10.0.2",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/swagger": "^7.1.17",
    "@types/hbs": "^4.0.5",
    "axios": "^1.6.2",
    "cache-manager": "^5.3.2",
    "cache-manager-redis-store": "^3.0.1",
    "chart.js": "^4.4.1",
    "cheerio": "^0.22.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "csvtojson": "^2.0.10",
    "hbs": "^4.2.0",
    "ioredis": "^5.3.2",
    "lightweight-charts": "^4.1.3",
    "lodash": "^4.17.21",
    "luxon": "^3.4.4",
    "moment-timezone": "^0.5.44",
    "mongoose": "^8.0.3",
    "numeral": "^2.0.6",
    "puppeteer": "^21.11.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "technicalindicators": "^3.1.0",
    "yahoo-finance2": "^3.13.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/lodash": "^4.14.202",
    "@types/luxon": "^3.3.7",
    "@types/node": "^20.3.1",
    "@types/numeral": "^2.0.5",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
