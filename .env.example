# ================================
# 台股智能分析系統 - 環境變數配置
# ================================

# 應用程式設定
NODE_ENV=development
PORT=3000
APP_NAME=TW-Stock-Analysis

# MongoDB 設定 (專用資料庫)
MONGODB_URI=mongodb://localhost:27018/tw_stock_analysis
MONGODB_HOST=localhost
MONGODB_PORT=27018
MONGODB_DATABASE=tw_stock_analysis
MONGODB_USER=
MONGODB_PASSWORD=

# Redis 快取設定 (專用實例)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0

# 快取策略設定 (秒)
CACHE_TTL=300
CACHE_TTL_SHORT=60
CACHE_TTL_LONG=3600
CACHE_MAX_ITEMS=1000

# API 限流設定
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# 資料來源 API 金鑰
FINMIND_API_TOKEN=
YAHOO_FINANCE_API_KEY=

# 爬蟲設定
SCRAPER_TIMEOUT=30000
SCRAPER_RETRY_TIMES=3
SCRAPER_DELAY=1000

# 排程設定
ENABLE_SCHEDULER=true
FETCH_DAILY_CRON=0 15 * * 1-5
FETCH_MONTHLY_CRON=0 16 10 * *

# 日誌設定
LOG_LEVEL=info
LOG_FILE_ENABLED=true
LOG_DIR=./logs

# Swagger 文檔
SWAGGER_ENABLED=true
SWAGGER_PATH=api-docs

# 安全性
CORS_ENABLED=true
CORS_ORIGIN=*

# 效能監控
PERFORMANCE_MONITORING=true
