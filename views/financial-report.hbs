<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <link rel="stylesheet" href="/public/css/styles.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
</head>
<body>
  <!-- Header -->
  <header class="header">
    <div class="container">
      <div class="header-content">
        <a href="/view" class="logo">📊 台股智能分析系統</a>
        <nav class="nav">
          <a href="/view">首頁</a>
          <a href="/view/financial/{{symbol}}">財報分析</a>
          <a href="/view/dupont/{{symbol}}">杜邦分析</a>
          <a href="/view/chart/{{symbol}}">股價走勢</a>
          <a href="/view/dashboard/{{symbol}}">綜合儀表板</a>
        </nav>
      </div>
    </div>
  </header>

  <!-- Main Content -->
  <main class="container">
    {{#if error}}
    <!-- Error Message -->
    <div class="alert alert-error" style="margin-top: 2rem;">
      <strong>❌ 錯誤：</strong> {{error}}
    </div>
    <p style="margin-top: 1rem;">
      <a href="/view" class="btn btn-primary">返回首頁</a>
    </p>
    {{else}}
    
    <!-- Company Info -->
    <section style="margin: 2rem 0;">
      <div class="card">
        <h1 style="color: #1e293b; margin-bottom: 0.5rem;">
          {{report.companyName}} ({{symbol}})
        </h1>
        <p style="color: #64748b;">
          會計期間：{{report.fiscalYear}} 年 {{report.fiscalPeriod}} | 
          資料來源：{{report.dataSource}} | 
          更新時間：{{report.reportDate}}
        </p>
      </div>
    </section>

    <!-- Quick Stats -->
    <section style="margin: 2rem 0;">
      <div class="grid grid-3">
        <div class="stat-box">
          <div class="stat-value">{{report.ratios.eps}}</div>
          <div class="stat-label">EPS (元)</div>
        </div>
        <div class="stat-box">
          <div class="stat-value {{#if report.ratios.roe}}{{#if (gt report.ratios.roe 15)}}positive{{/if}}{{/if}}">
            {{report.ratios.roe}}%
          </div>
          <div class="stat-label">ROE</div>
        </div>
        <div class="stat-box">
          <div class="stat-value">{{report.ratios.debtRatio}}%</div>
          <div class="stat-label">負債比率</div>
        </div>
      </div>
    </section>

    <!-- 損益表 -->
    <section style="margin: 2rem 0;">
      <div class="card">
        <div class="card-header">
          <h2 class="card-title">📈 綜合損益表</h2>
          <span class="badge badge-info">單位：千元</span>
        </div>
        <div class="table-wrapper">
          <table class="financial-table">
            <thead>
              <tr>
                <th>項目</th>
                <th class="text-right">金額</th>
                <th class="text-right">%</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="row-header">營業收入</td>
                <td class="text-right fw-bold">{{formatNumber report.incomeStatement.revenue}}</td>
                <td class="text-right">100.0%</td>
              </tr>
              <tr>
                <td class="indent-1">營業成本</td>
                <td class="text-right">{{formatNumber report.incomeStatement.costOfRevenue}}</td>
                <td class="text-right">
                  {{formatPercent (divide report.incomeStatement.costOfRevenue report.incomeStatement.revenue)}}
                </td>
              </tr>
              <tr style="background: #f8fafc;">
                <td class="row-header">營業毛利</td>
                <td class="text-right fw-bold positive">{{formatNumber report.incomeStatement.grossProfit}}</td>
                <td class="text-right positive">{{report.incomeStatement.grossMargin}}%</td>
              </tr>
              <tr>
                <td class="indent-1">營業費用</td>
                <td class="text-right">{{formatNumber report.incomeStatement.operatingExpenses}}</td>
                <td class="text-right">
                  {{formatPercent (divide report.incomeStatement.operatingExpenses report.incomeStatement.revenue)}}
                </td>
              </tr>
              <tr style="background: #f8fafc;">
                <td class="row-header">營業利益</td>
                <td class="text-right fw-bold {{#if (gt report.incomeStatement.operatingIncome 0)}}positive{{else}}negative{{/if}}">
                  {{formatNumber report.incomeStatement.operatingIncome}}
                </td>
                <td class="text-right">{{report.incomeStatement.operatingMargin}}%</td>
              </tr>
              <tr>
                <td class="indent-1">營業外收支</td>
                <td class="text-right">{{formatNumber report.incomeStatement.nonOperatingIncome}}</td>
                <td class="text-right">-</td>
              </tr>
              <tr style="background: #f8fafc;">
                <td class="row-header">稅前淨利</td>
                <td class="text-right fw-bold">{{formatNumber report.incomeStatement.pretaxIncome}}</td>
                <td class="text-right">
                  {{formatPercent (divide report.incomeStatement.pretaxIncome report.incomeStatement.revenue)}}
                </td>
              </tr>
              <tr>
                <td class="indent-1">所得稅費用</td>
                <td class="text-right">{{formatNumber report.incomeStatement.incomeTax}}</td>
                <td class="text-right">-</td>
              </tr>
              <tr style="background: #dbeafe;">
                <td class="row-header fw-bold" style="color: #1e40af;">本期淨利</td>
                <td class="text-right fw-bold" style="color: #1e40af; font-size: 1.1rem;">
                  {{formatNumber report.incomeStatement.netIncome}}
                </td>
                <td class="text-right fw-bold" style="color: #1e40af;">
                  {{report.incomeStatement.netMargin}}%
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- 資產負債表 -->
    <section style="margin: 2rem 0;">
      <div class="card">
        <div class="card-header">
          <h2 class="card-title">💰 資產負債表</h2>
          <span class="badge badge-info">單位：千元</span>
        </div>
        <div class="table-wrapper">
          <table class="financial-table">
            <thead>
              <tr>
                <th>項目</th>
                <th class="text-right">金額</th>
                <th class="text-right">%</th>
              </tr>
            </thead>
            <tbody>
              <!-- 資產 -->
              <tr style="background: #dbeafe;">
                <td class="row-header fw-bold" style="color: #1e40af;">資產總額</td>
                <td class="text-right fw-bold" style="color: #1e40af; font-size: 1.1rem;">
                  {{formatNumber report.balanceSheet.totalAssets}}
                </td>
                <td class="text-right">100.0%</td>
              </tr>
              <tr>
                <td class="indent-1">流動資產</td>
                <td class="text-right">{{formatNumber report.balanceSheet.currentAssets}}</td>
                <td class="text-right">
                  {{formatPercent (divide report.balanceSheet.currentAssets report.balanceSheet.totalAssets)}}
                </td>
              </tr>
              <tr>
                <td class="indent-1">非流動資產</td>
                <td class="text-right">
                  {{formatNumber (subtract report.balanceSheet.totalAssets report.balanceSheet.currentAssets)}}
                </td>
                <td class="text-right">
                  {{formatPercent (divide (subtract report.balanceSheet.totalAssets report.balanceSheet.currentAssets) report.balanceSheet.totalAssets)}}
                </td>
              </tr>
              <!-- 負債 -->
              <tr style="background: #fee2e2; margin-top: 1rem;">
                <td class="row-header fw-bold" style="color: #991b1b;">負債總額</td>
                <td class="text-right fw-bold" style="color: #991b1b; font-size: 1.1rem;">
                  {{formatNumber report.balanceSheet.totalLiabilities}}
                </td>
                <td class="text-right">
                  {{formatPercent (divide report.balanceSheet.totalLiabilities report.balanceSheet.totalAssets)}}
                </td>
              </tr>
              <tr>
                <td class="indent-1">流動負債</td>
                <td class="text-right">{{formatNumber report.balanceSheet.currentLiabilities}}</td>
                <td class="text-right">
                  {{formatPercent (divide report.balanceSheet.currentLiabilities report.balanceSheet.totalAssets)}}
                </td>
              </tr>
              <tr>
                <td class="indent-1">非流動負債</td>
                <td class="text-right">
                  {{formatNumber (subtract report.balanceSheet.totalLiabilities report.balanceSheet.currentLiabilities)}}
                </td>
                <td class="text-right">
                  {{formatPercent (divide (subtract report.balanceSheet.totalLiabilities report.balanceSheet.currentLiabilities) report.balanceSheet.totalAssets)}}
                </td>
              </tr>
              <!-- 股東權益 -->
              <tr style="background: #d1fae5;">
                <td class="row-header fw-bold" style="color: #065f46;">股東權益</td>
                <td class="text-right fw-bold" style="color: #065f46; font-size: 1.1rem;">
                  {{formatNumber report.balanceSheet.equity}}
                </td>
                <td class="text-right">
                  {{formatPercent (divide report.balanceSheet.equity report.balanceSheet.totalAssets)}}
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- EPS / ROE 趨勢圖 -->
    <section style="margin: 2rem 0;">
      <div class="grid grid-2">
        <!-- EPS 趨勢 -->
        <div class="card">
          <div class="card-header">
            <h3 class="card-title">📊 EPS 趨勢（近 8 季）</h3>
          </div>
          <div class="chart-container">
            <canvas id="epsChart"></canvas>
          </div>
        </div>

        <!-- ROE 趨勢 -->
        <div class="card">
          <div class="card-header">
            <h3 class="card-title">📊 ROE 趨勢（近 8 季）</h3>
          </div>
          <div class="chart-container">
            <canvas id="roeChart"></canvas>
          </div>
        </div>
      </div>
    </section>

    <!-- 杜邦分析預覽 -->
    <section style="margin: 2rem 0;">
      <div class="card">
        <div class="card-header">
          <h2 class="card-title">🔬 杜邦分析（ROE 拆解）</h2>
          <a href="/view/dupont/{{symbol}}" class="btn btn-primary">查看完整分析</a>
        </div>
        <div class="grid grid-3">
          <div class="stat-box">
            <div class="stat-value {{#if (gt dupontAnalysis.netMargin 20)}}positive{{/if}}">
              {{dupontAnalysis.netMargin}}%
            </div>
            <div class="stat-label">淨利率（獲利能力）</div>
          </div>
          <div class="stat-box">
            <div class="stat-value {{#if (gt dupontAnalysis.assetTurnover 0.8)}}positive{{/if}}">
              {{dupontAnalysis.assetTurnover}}
            </div>
            <div class="stat-label">資產週轉率（經營效率）</div>
          </div>
          <div class="stat-box">
            <div class="stat-value {{#if (lt dupontAnalysis.equityMultiplier 2.5)}}positive{{/if}}">
              {{dupontAnalysis.equityMultiplier}}
            </div>
            <div class="stat-label">權益乘數（財務槓桿）</div>
          </div>
        </div>
        <div style="margin-top: 1.5rem; padding: 1rem; background: #f8fafc; border-radius: 0.5rem;">
          <p style="font-size: 0.875rem; color: #64748b; margin-bottom: 0.5rem;">
            <strong>分析公式：</strong>
          </p>
          <p style="font-size: 1rem; color: #1e293b; font-family: 'Courier New', monospace;">
            ROE = 淨利率 × 資產週轉率 × 權益乘數
          </p>
          <p style="font-size: 1rem; color: #1e293b; font-family: 'Courier New', monospace; margin-top: 0.5rem;">
            = {{dupontAnalysis.netMargin}}% × {{dupontAnalysis.assetTurnover}} × {{dupontAnalysis.equityMultiplier}}
            = {{dupontAnalysis.roe}}%
          </p>
        </div>
      </div>
    </section>

    {{/if}}
  </main>

  <!-- Footer -->
  <footer style="background: white; border-top: 1px solid #e2e8f0; padding: 2rem 0; margin-top: 4rem; text-align: center; color: #64748b; font-size: 0.875rem;">
    <div class="container">
      <p>台股智能分析系統 v2.1.0 | ⚠️ 本系統僅供學習研究使用</p>
    </div>
  </footer>

  <script>
    {{#unless error}}
    // EPS 趨勢圖
    const epsData = {{{json epsTrend}}};
    const epsLabels = epsData.map(d => `${d.fiscalYear} ${d.fiscalPeriod}`);
    const epsValues = epsData.map(d => d.eps);

    new Chart(document.getElementById('epsChart'), {
      type: 'line',
      data: {
        labels: epsLabels.reverse(),
        datasets: [{
          label: 'EPS (元)',
          data: epsValues.reverse(),
          borderColor: '#2563eb',
          backgroundColor: 'rgba(37, 99, 235, 0.1)',
          borderWidth: 2,
          tension: 0.4,
          fill: true
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: (context) => `EPS: ${context.parsed.y.toFixed(2)} 元`
            }
          }
        },
        scales: {
          y: {
            beginAtZero: true,
            title: { display: true, text: 'EPS (元)' }
          }
        }
      }
    });

    // ROE 趨勢圖
    const roeData = {{{json roeTrend}}};
    const roeLabels = roeData.map(d => `${d.fiscalYear} ${d.fiscalPeriod}`);
    const roeValues = roeData.map(d => d.roe);

    new Chart(document.getElementById('roeChart'), {
      type: 'line',
      data: {
        labels: roeLabels.reverse(),
        datasets: [{
          label: 'ROE (%)',
          data: roeValues.reverse(),
          borderColor: '#10b981',
          backgroundColor: 'rgba(16, 185, 129, 0.1)',
          borderWidth: 2,
          tension: 0.4,
          fill: true
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: (context) => `ROE: ${context.parsed.y.toFixed(2)}%`
            }
          }
        },
        scales: {
          y: {
            beginAtZero: true,
            title: { display: true, text: 'ROE (%)' }
          }
        }
      }
    });
    {{/unless}}
  </script>
</body>
</html>
